# Copy this to .env and fill in values — never commit .env to git

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Atlas API
APP_VERSION=0.1.0
DEBUG=true

# ── Database (Task 3) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas_db

# ── LLM (Task 4) ───────────────────────────────────────────────────────────────
# Default provider is NVIDIA NIM (OpenAI-compatible). LLM_API_KEY is required
# for any provider other than "ollama" — the app will refuse to start without it.
LLM_PROVIDER=nvidia_nim         # "nvidia_nim" | "ollama" | any OpenAI-compatible provider
LLM_MODEL=meta/llama-3.1-70b-instruct
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=                    # required — get from https://build.nvidia.com

# To use local Ollama instead, comment out the block above and uncomment this:
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=

# ── Security ───────────────────────────────────────────────────────────────────
API_KEY_HEADER=X-Atlas-Key
