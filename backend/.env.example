# Copy this to .env and fill in values — never commit .env to git

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Atlas API
APP_VERSION=0.1.0
DEBUG=true

# ── Database (Task 3) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas_db

# ── LLM (Task 4) ───────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama            # "ollama" | "openai" | "groq"
LLM_MODEL=llama3
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=                   # leave blank for local Ollama

# ── Security ───────────────────────────────────────────────────────────────────
API_KEY_HEADER=X-Atlas-Key
