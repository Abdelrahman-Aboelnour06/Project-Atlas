# Copy this to .env and fill in values — never commit .env to git

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Atlas API
APP_VERSION=0.1.0
DEBUG=true

# ── Database (Task 3) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas_db

# ── LLM (Task 4) ───────────────────────────────────────────────────────────────
LLM_PROVIDER=nim
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama3-8b-instruct
LLM_API_KEY=nvapi-your-actual-api-key-here                 # leave blank for local Ollama

# ── Security ───────────────────────────────────────────────────────────────────
API_KEY_HEADER=X-Atlas-Key
